Categories with total course fee above 15000

select category,sum(fee) as total_fee
from courses
GROUP BY category
HAVING total_fee > 15000


select category,sum(fee) as total_fee
from courses
GROUP BY category
HAVING sum(fee) > 15000


-- select queries with offset,limit TOP-N queries
-- Useful shorthand, but flag it as a readability trade-off 
-- encourage students to prefer column names in real projects.
SELECT course_name, fee FROM courses ORDER BY 2 DESC;

SELECT course_name, fee FROM courses ORDER BY fee DESC LIMIT 5;

select course_name, fee FROM courses ORDER BY fee DESC LIMIT 5 offset 7;
SELECT course_name, fee FROM courses ORDER BY fee


